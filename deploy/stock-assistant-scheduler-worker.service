[Unit]
Description=Stock Assistant durable schedule worker
After=network-online.target postgresql.service redis-server.service
Wants=network-online.target

[Service]
Type=simple
User=stockassistant
Group=stockassistant
UMask=0077
WorkingDirectory=/opt/stock-assistant/backend
EnvironmentFile=/etc/stock-assistant/stock-assistant.env
Environment="PYTHONUNBUFFERED=1"
Environment="PYTHONPATH=/opt/stock-assistant/backend"
Environment="SERVICE_NAME=stock-assistant-scheduler-worker"
Environment="LOG_FORMAT=json"
Environment="TASK_QUEUE_MODE=celery"
ExecStart=/opt/stock-assistant/venv/bin/celery -A task_queue:celery_app worker --queues=scheduler --hostname=scheduler@%H --concurrency=1 --pool=prefork --max-tasks-per-child=100 --without-gossip --without-mingle
Restart=always
RestartSec=5
TimeoutStopSec=90
KillSignal=SIGTERM
MemoryMax=700M
TasksMax=128
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/stock-assistant

[Install]
WantedBy=multi-user.target
