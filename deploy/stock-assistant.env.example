# Production authentication is enabled by the systemd unit.
# Generate once with: openssl rand -hex 32
AUTH_AUDIT_PEPPER=replace-with-at-least-32-random-characters

# Keep false only while the site is served over plain HTTP. Set true after HTTPS is active.
AUTH_COOKIE_SECURE=true
AUTH_SESSION_HOURS=12
AUTH_IDLE_MINUTES=120
AUTH_LOGIN_LIMIT=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_SELF_REGISTRATION_ENABLED=true
AUTH_REGISTRATION_LIMIT=5
AUTH_REGISTRATION_WINDOW_MINUTES=60
ALLOWED_ORIGINS=https://your-domain.com

# PostgreSQL is authoritative. Use URL-encoded credentials and never commit them.
DATABASE_URL=postgresql://stockassistant:replace-password@127.0.0.1:5432/stock_assistant
# Used only by the weekly isolated restore drill.
POSTGRES_ADMIN_URL=postgresql://postgres:replace-admin-password@127.0.0.1:5432/postgres

# Redis is a queue, not the source of truth. Keep it bound to localhost.
REDIS_URL=redis://:replace-redis-password@127.0.0.1:6379/0
TASK_QUEUE_MODE=celery
OPPORTUNITY_OBSERVATION_INTERVAL_SECONDS=3600
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
MARKET_DATA_API_WAIT_SECONDS=300
MARKET_DATA_JOB_LEASE_SECONDS=360

# Application-level availability control plane. The scheduled probe is
# idempotent per interval; two consecutive observations confirm a transition.
AVAILABILITY_PROBE_INTERVAL_SECONDS=300
AVAILABILITY_STALE_SECONDS=900
AVAILABILITY_FAILURE_THRESHOLD=2
AVAILABILITY_RECOVERY_THRESHOLD=2
AVAILABILITY_QUEUE_WARN_DEPTH=100
AVAILABILITY_QUEUE_OUTAGE_DEPTH=1000
# Internal objectives for error-budget reporting (percent, not customer SLA).
AVAILABILITY_SLO_CORE=99.9
AVAILABILITY_SLO_BACKGROUND=99.0
AVAILABILITY_SLO_PRIVATE_ASSET=99.0
AVAILABILITY_SLO_MARKET=95.0
# Same-host API replicas are identified explicitly and may only use credential-free
# loopback HTTP origins. The scheduler records quorum and release consistency.
API_REPLICA_ENDPOINTS=api-8001=http://127.0.0.1:8001,api-8002=http://127.0.0.1:8002
AVAILABILITY_SLO_API_TRAFFIC=99.9
AVAILABILITY_SLO_API_REDUNDANCY=99.0

# Professional market-ranking providers. Keep credentials server-side only.
# Tushare A-share daily and Hong Kong daily/basic APIs may require different
# account points or paid permissions. Alpha Vantage defaults to end-of-day when
# entitlement is blank; only set delayed/realtime when the subscription allows it.
TUSHARE_TOKEN=
# Massive（原 Polygon.io）免费档可提供美股全市场日终汇总。新部署使用
# MASSIVE_API_KEY；POLYGON_API_KEY 仅为旧账号/旧域名兼容。
MASSIVE_API_KEY=
MASSIVE_API_BASE_URL=https://api.massive.com
POLYGON_API_KEY=
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_MARKET_DATA_ENTITLEMENT=

# 可选：富途 OpenD 实时快照。仅在 OpenD 已安全运行并完成登录后填写 HOST。
# MARKET 可写 A,H,US（逗号分隔）；快照单次上限 400。
FUTU_OPEND_HOST=
FUTU_OPEND_PORT=11111
FUTU_OPEND_MARKETS=A,H,US
FUTU_SNAPSHOT_BATCH_SIZE=400

# 美股全市场榜单流动性过滤，避免极低价/极低成交标的污染榜首。
HOT_STOCK_US_MIN_PRICE=1
HOT_STOCK_US_MIN_VOLUME=10000

# Public web endpoints are best-effort degraded fallbacks, never professional
# sources. Disable in strict production after professional providers are ready.
HOT_STOCK_PUBLIC_FALLBACK_ENABLED=true
HOT_STOCK_PROVIDER_FAILURE_THRESHOLD=2
HOT_STOCK_PROVIDER_CIRCUIT_SECONDS=300

# Alibaba Cloud private OSS. OBJECT_KEY_PEPPER: openssl rand -hex 32
# Must match the server region when OSS_USE_INTERNAL_ENDPOINT=true.
OSS_REGION=cn-wuhan-lr
OSS_BUCKET=replace-private-bucket
OSS_USE_INTERNAL_ENDPOINT=true
OSS_SSE_MODE=AES256
OBJECT_KEY_PEPPER=replace-with-at-least-32-random-characters
OCR_OBJECT_RETENTION_HOURS=24
REQUIRE_OBJECT_STORAGE=true

# Existing OCR and model credentials remain server-side only.
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=
LLM_PRIVATE_CONTEXT_ENABLED=false

# Verified PostgreSQL backup and encrypted offsite copy.
BACKUP_DIR=/var/backups/stock-assistant/postgresql
BACKUP_RETENTION_DAYS=14
BACKUP_UPLOAD_ENABLED=1
APP_VENV=/opt/stock-assistant/venv

LOG_FORMAT=json
LOG_LEVEL=INFO
