[Unit]
Description=Stock Assistant dependency and worker health check
After=stock-assistant-api.service

[Service]
Type=oneshot
User=stockassistant
Group=stockassistant
Environment="HEALTHCHECK_URL=http://127.0.0.1:8000/health/ready"
ExecStart=/opt/stock-assistant/deploy/scripts/check-runtime.sh
TimeoutStartSec=20
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

